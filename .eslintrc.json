{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "react-app",
    "react-app/jest",
    "plugin:@typescript-eslint/recommended",
    "plugin:jsx-a11y/recommended",
    "plugin:security/recommended-legacy"
  ],
  "plugins": [
    "@typescript-eslint",
    "jsx-a11y",
    "security"
  ],
  "rules": {
    // ── Sécurité ──────────────────────────────────────────────
    // Bloque l'usage de eval() et Function() dynamique (risque XSS/injection)
    "no-eval": "error",
    "no-new-func": "error",
    // Bloque innerHTML et outerHTML (risque XSS)
    "security/detect-non-literal-regexp": "warn",
    "security/detect-object-injection": "warn",
    "security/detect-possible-timing-attacks": "warn",
    // Bloque dangerouslySetInnerHTML sauf annotation explicite
    "react/no-danger": "error",
    // Vérifie que tous les liens externes ont rel="noopener noreferrer"
    "react/jsx-no-target-blank": ["error", { "allowReferrer": false }],

    // ── Accessibilité (WCAG 2.1) ──────────────────────────────
    // Images doivent avoir un alt
    "jsx-a11y/alt-text": "error",
    // Liens doivent avoir un contenu accessible
    "jsx-a11y/anchor-has-content": "error",
    // Liens valides (href non-vide)
    "jsx-a11y/anchor-is-valid": "error",
    // aria-* doivent être valides
    "jsx-a11y/aria-props": "error",
    "jsx-a11y/aria-proptypes": "error",
    "jsx-a11y/aria-unsupported-elements": "error",
    // role valides
    "jsx-a11y/aria-role": "error",
    // Interactivité clavier sur les éléments cliquables
    "jsx-a11y/click-events-have-key-events": "warn",
    "jsx-a11y/interactive-supports-focus": "warn",
    // Labels doivent être associés à leurs champs
    "jsx-a11y/label-has-associated-control": "error",
    // Headings dans l'ordre hiérarchique
    "jsx-a11y/heading-has-content": "error",

    // ── TypeScript ─────────────────────────────────────────────
    // Interdit les types any explicites
    "@typescript-eslint/no-explicit-any": "warn",
    // Interdit les variables non utilisées
    "@typescript-eslint/no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    // Préfère les interfaces aux types pour les objets
    "@typescript-eslint/consistent-type-definitions": ["warn", "interface"],

    // ── Qualité générale ───────────────────────────────────────
    // Interdit console.log en production (autoriser console.error et console.warn)
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    // Pas de variables redéclarées
    "no-redeclare": "error",
    // Pas de variables non déclarées
    "no-undef": "off" // Géré par TypeScript
  },
  "overrides": [
    {
      // Règles plus souples pour les fichiers de test
      "files": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts"],
      "rules": {
        "no-console": "off",
        "@typescript-eslint/no-explicit-any": "off",
        "security/detect-object-injection": "off"
      }
    }
  ]
}
